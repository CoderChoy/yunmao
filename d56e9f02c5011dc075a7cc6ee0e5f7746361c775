con_y = (height - icon_size) // 2\n    img.alpha_composite(icon, (icon_x, icon_y))\n\n    d = ImageDraw.Draw(img)\n    title_font = ImageFont.truetype(FONT_BOLD, int(height * 0.28))\n    sub_font = ImageFont.truetype(FONT_REG, int(height * 0.12))\n    title = 'YUN MAO'\n    subtitle = 'Home Assistant integration'\n    title_color = TEXT_DARK if dark else TEXT\n    sub_color = TEXT_SUB_DARK if dark else TEXT_SUB\n    text_x = icon_x + icon_size + int(height * 0.11)\n    title_y = int(height * 0.26)\n    d.text((text_x, title_y), title, font=title_font, fill=title_color)\n    d.text((text_x, title_y + int(height * 0.30)), subtitle, font=sub_font, fill=sub_color)\n\n    accent_y = title_y + int(height * 0.54)\n    d.rounded_rectangle(\n        (text_x, accent_y, text_x + int(height * 0.38), accent_y + max(6, height // 28)),\n        radius=max(3, height // 50),\n        fill=ACCENT,\n    )\n    return img\n\nassets = {\n    'icon.png': icon_image(256, dark=False),\n    'icon@2x.png': icon_image(512, dark=False),\n    'dark_icon.png': icon_image(256, dark=True),\n    'dark_icon@2x.png': icon_image(512, dark=True),\n    'logo.png': logo_image(640, 256, dark=False),\n    'logo@2x.png': logo_image(1280, 512, dark=False),\n    'dark_logo.png': logo_image(640, 256, dark=True),\n    'dark_logo@2x.png': logo_image(1280, 512, dark=True),\n}\n\nfor name, image in assets.items():\n    image.save(root / name)\n    print(name, image.size)\nPY",
